{
  "name": "pykaraoke-ng-e2e",
  "version": "0.7.5",
  "private": true,
  "description": "BDD end-to-end tests for PyKaraoke NG (Cucumber.js + WebdriverIO)",
  "scripts": {
    "test:e2e": "cucumber-js --config cucumber.js",
    "test:e2e:watch": "nodemon --ext feature,ts,js --watch features --watch steps --watch support -- npx cucumber-js --config cucumber.js",
    "test:e2e:ci": "cucumber-js --config cucumber.ci.js --format json:reports/e2e-results.json --format html:reports/e2e-report.html --fail-fast"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.3.0",
    "@wdio/globals": "^8.36.0",
    "@wdio/local-runner": "^8.36.0",
    "@wdio/mocha-framework": "^8.36.0",
    "@wdio/spec-reporter": "^8.36.0",
    "chai": "^4.4.1",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "webdriverio": "^8.36.0"
  }
}
